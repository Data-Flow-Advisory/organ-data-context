{
  "_README": "The shared connection-type vocabulary \u2014 the stud sizes. Two organ ports connect iff their `type` matches. Curated deliberately: a new type is added only when no existing one fits (sprawl defeats the standard). Each type pins the shape that flows on that wire. See CONNECTORS.md.",
  "version": 1,
  "types": {
    "TenantContext": {
      "desc": "A resolved tenant: identity, branding, provenance bag.",
      "schema": {
        "tenant_id": "int",
        "slug": "str",
        "brand": "object",
        "provenance": "object"
      },
      "produced_by_eg": [
        "organ-tenant"
      ],
      "consumed_by_eg": [
        "organ-branding",
        "organ-system-blueprint"
      ]
    },
    "SiteCrawl": {
      "desc": "Signals crawled from a prospect's website at signup.",
      "schema": {
        "url": "str",
        "industry": "str",
        "competitors": "array",
        "palette": "array",
        "description": "str"
      },
      "produced_by_eg": [
        "organ-site-crawl"
      ],
      "consumed_by_eg": [
        "organ-branding",
        "organ-tenant"
      ]
    },
    "InterviewTranscript": {
      "desc": "Ordered Q&A pairs from a discovery interview.",
      "schema": {
        "interview_id": "int",
        "qa": "array<{question:str,answer:str,asked_at:str}>"
      },
      "produced_by_eg": [
        "organ-claude-service"
      ],
      "consumed_by_eg": [
        "organ-fact-extractor",
        "organ-process-flow"
      ]
    },
    "KeyFacts": {
      "desc": "Themed facts extracted from a transcript (the discovery memory).",
      "schema": {
        "facts": "array<{theme:str,fact:str,evidence:array}>"
      },
      "produced_by_eg": [
        "organ-fact-extractor"
      ],
      "consumed_by_eg": [
        "organ-system-blueprint",
        "organ-entity-deduplication-service"
      ]
    },
    "EntityGraph": {
      "desc": "Deduplicated canonical entities (people, systems, tools) per tenant.",
      "schema": {
        "entities": "array<{canonical:str,aliases:array,kind:str}>"
      },
      "produced_by_eg": [
        "organ-entity-deduplication-service"
      ],
      "consumed_by_eg": [
        "organ-system-blueprint"
      ]
    },
    "Blueprint": {
      "desc": "The system blueprint: modules + integrations + current/recommended state.",
      "schema": {
        "modules": "array<{name:str,integrations:array,screen_concept:str}>",
        "integrations": "array<{name:str,purpose:str}>"
      },
      "produced_by_eg": [
        "organ-system-blueprint"
      ],
      "consumed_by_eg": [
        "organ-solutions-engine",
        "organ-react-flow-blueprint",
        "organ-pdf-report"
      ]
    },
    "RecommendationList": {
      "desc": "SaaS + bespoke-build recommendations, competitor-weighted.",
      "schema": {
        "recommendations": "array<{name:str,purpose:str,kind:str}>"
      },
      "produced_by_eg": [
        "organ-solutions-engine"
      ],
      "consumed_by_eg": [
        "organ-pdf-report"
      ]
    },
    "ProcessFlow": {
      "desc": "Sequence / swimlane of a workflow extracted from transcript themes.",
      "schema": {
        "steps": "array<{actor:str,action:str,system:str}>"
      },
      "produced_by_eg": [
        "organ-process-flow"
      ],
      "consumed_by_eg": [
        "organ-react-flow-blueprint"
      ]
    },
    "AccountState": {
      "desc": "A fleet account's pacing/quota state (the pace + drift gates' input).",
      "schema": {
        "utilization_pct": "number",
        "resets_at": "str",
        "tier_cap_4h": "int"
      },
      "produced_by_eg": [
        "organ-account-health"
      ],
      "consumed_by_eg": [
        "organ-pace-gate",
        "organ-drift-gate",
        "organ-burn-pacing"
      ]
    },
    "PendingItems": {
      "desc": "Work items awaiting prioritisation (APES input).",
      "schema": {
        "items": "array<{id:any,atoms:object}>"
      },
      "produced_by_eg": [
        "organ-feed-adapters-github-adapter"
      ],
      "consumed_by_eg": [
        "organ-prioritiser"
      ]
    },
    "RankedItems": {
      "desc": "APES-ranked items + human-decision / culled buckets.",
      "schema": {
        "ranked": "array",
        "human_decision": "array",
        "culled": "array"
      },
      "produced_by_eg": [
        "organ-prioritiser"
      ],
      "consumed_by_eg": [
        "organ-queue-admission"
      ]
    },
    "ClaimVerdict": {
      "desc": "Whether a worker may claim work now, and why (gate output).",
      "schema": {
        "allow": "bool",
        "reason": "str"
      },
      "produced_by_eg": [
        "organ-pace-gate",
        "organ-drift-gate",
        "organ-queue-admission"
      ],
      "consumed_by_eg": [
        "organ-claim-router"
      ]
    },
    "BillingState": {
      "desc": "A tenant's subscription / billing state + feature entitlements.",
      "schema": {
        "tier": "str",
        "status": "str",
        "features": "array"
      },
      "produced_by_eg": [
        "organ-airwallex-billing",
        "organ-billing-provider"
      ],
      "consumed_by_eg": [
        "organ-feature-gates"
      ]
    },
    "ConformanceVerdict": {
      "desc": "Whether an organ/output conforms + groundedness (self_metric shape).",
      "schema": {
        "conforms": "bool",
        "confidence": "number",
        "reasons": "array"
      },
      "produced_by_eg": [
        "organ-readiness"
      ],
      "consumed_by_eg": []
    },
    "ApparatusSource": {
      "desc": "A pointer to something the fresh apparatus should scan for useful specs/features \u2014 the OLD apparatus or any source.",
      "schema": {
        "kind": "discovery-engine|notion|github|transcript|docs|rebuild-backlog",
        "ref": "str"
      },
      "produced_by_eg": [],
      "consumed_by_eg": [
        "organ-discernment"
      ]
    },
    "RawArtefacts": {
      "desc": "Raw scanned content from a source, before it is decomposed into discrete features.",
      "schema": {
        "items": "array"
      },
      "produced_by_eg": [
        "organ-discernment"
      ],
      "consumed_by_eg": [
        "organ-decompose-to-execute"
      ]
    },
    "CandidateFeatures": {
      "desc": "Discrete specs/features decomposed out of the raw scan \u2014 the candidates to judge.",
      "schema": {
        "features": "array<{title:str,spec:str,source_ref:str}>"
      },
      "produced_by_eg": [
        "organ-decompose-to-execute"
      ],
      "consumed_by_eg": [
        "organ-prioritiser"
      ]
    },
    "JudgedFeatures": {
      "desc": "Candidates after judgment \u2014 the useful ranked, the useless rejected (reject is first-class).",
      "schema": {
        "useful": "array",
        "rejected": "array"
      },
      "produced_by_eg": [
        "organ-prioritiser"
      ],
      "consumed_by_eg": [
        "organ-readiness"
      ]
    },
    "ProvenancedArtefact": {
      "desc": "Any spec/feature the scan-and-select takes from the OLD apparatus, wrapped with its origin + succession status so the new machine knows it as inherited, never native. Retain history, know it as such \u2014 succession baked in, the antidote to old-artefacts-polluting-new. See FRESH_APPARATUS.md.",
      "schema": {
        "artefact": "object",
        "provenance": {
          "source": "str",
          "origin_ref": "str",
          "scanned_at": "str"
        },
        "succession": {
          "status": "inherited|validated|native|superseded|retired",
          "native": "bool"
        }
      },
      "produced_by_eg": [
        "organ-discernment"
      ],
      "consumed_by_eg": [
        "the-fresh-apparatus-injector"
      ]
    },
    "str": {
      "desc": "JSON string scalar. A primitive port type for control/text wires.",
      "schema": "str",
      "_proposed": true,
      "produced_by_eg": [],
      "consumed_by_eg": []
    },
    "int": {
      "desc": "JSON integer scalar (counts, ids). A primitive port type.",
      "schema": "int",
      "_proposed": true,
      "produced_by_eg": [],
      "consumed_by_eg": []
    },
    "bool": {
      "desc": "JSON boolean scalar (flags/gates). A primitive port type.",
      "schema": "bool",
      "_proposed": true,
      "produced_by_eg": [],
      "consumed_by_eg": []
    },
    "ConnectorSummaries": {
      "desc": "Pre-fetched per-connection data summaries for a tenant's attached data sources (CSV/Sheets/VisualSoft). Each entry is a connector's summarise() dict, or null when the connector was unbuildable.",
      "schema": {
        "connections": "array<{name:str, summary:object|null}>"
      },
      "_proposed": true,
      "produced_by_eg": [
        "organ-connectors-crm-base",
        "io-connector-organs"
      ],
      "consumed_by_eg": [
        "organ-data-context"
      ]
    },
    "ValidationList": {
      "desc": "Answer-vs-data validations: claims an interviewee made checked against the connected data, with a severity. Raw on the way in, clamped/cleaned on the way out.",
      "schema": {
        "validations": "array<{claim:str, data_shows:str, source:str, severity:contradiction|discrepancy|note}>"
      },
      "_proposed": true,
      "produced_by_eg": [
        "organ-data-context"
      ],
      "consumed_by_eg": [
        "organ-data-context",
        "organ-pdf-report"
      ]
    },
    "QuestionList": {
      "desc": "Data-informed interview questions derived from the connected data, capped to a small set. Raw on the way in, stringified/capped out.",
      "schema": {
        "questions": "array<str>"
      },
      "_proposed": true,
      "produced_by_eg": [
        "organ-data-context"
      ],
      "consumed_by_eg": [
        "organ-claude-service"
      ]
    }
  },
  "_vendored": "Pinned snapshot of orchestrator@feat/drift-gate types.json. Types tagged \"_proposed\": true are local additions from the organ-data-context ports PR, proposed for upstream into the canonical vocabulary. See CONNECTORS.md and this repo's README."
}
